# Canonical production URL used for SEO metadata, sitemap.xml, and robots.txt.
SITE_URL=https://www.restaurant-carpe-diem.de

# AWS SES email settings for reservation and contact emails.
AWS_SES_REGION=eu-central-1
EMAIL_FROM=Carpe Diem <noreply@restaurant-carpe-diem.de>
RESERVATION_NOTIFICATION_TO=info@restaurant-carpe-diem.de
CONTACT_NOTIFICATION_TO=info@restaurant-carpe-diem.de
EMAIL_REPLY_TO=info@restaurant-carpe-diem.de
RESTAURANT_CONTACT_EMAIL=info@restaurant-carpe-diem.de
RESTAURANT_PHONE=+49 30 711 36 44

# Google Search Console meta-tag verification token.
# Use only the content value, not the whole meta tag.
GOOGLE_SITE_VERIFICATION=

# Google Analytics 4 Measurement ID, for example G-XXXXXXXXXX.
NEXT_PUBLIC_GA_ID=G-K6NB5FTD9H
